feeds:
  - url: "https://hnrss.org/frontpage"
    name: "Hacker News"
  - url: "https://feeds.arstechnica.com/arstechnica/index"
    name: "Ars Technica"
  - url: "https://api.quantamagazine.org/feed/"
    name: "Quanta Magazine"
  - url: "https://www.theregister.com/headlines.atom"
    name: "The Register"

# Mount path of your Kobo when connected via USB.
# Leave empty to let briefme auto-detect it.
#
# Common paths:
#   macOS:   /Volumes/KOBOeReader
#   Linux:   /media/<your-username>/KOBOeReader
#            /run/media/<your-username>/KOBOeReader
#   Windows: E:\   (or whichever drive letter Windows assigns)
#
kobo_path: ""

max_per_feed: 5   # articles fetched per feed; total = feeds × max_per_feed
